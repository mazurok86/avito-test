# --- Server ---
PORT=3000

# --- Avito ---
# Avito login + password are NOT stored on disk. The auth flow asks for them
# through the UI (POST /auth/credentials) when a fresh login is needed,
# emitting the `auth:needs_credentials` socket event so the frontend can
# show the form. After a successful login the session cookies persist in
# the Chrome profile volume — subsequent restarts skip the prompt until
# the session expires or Avito invalidates it.

# Substring to match the target chat partner's display name (case-insensitive)
TARGET_USER_NAME=

# --- Puppeteer ---
# Persistent Chromium profile dir (keeps you logged in between restarts).
# Chrome always runs headful (under Xvfb in Docker, real display locally) —
# headless mode is fingerprinted by Avito and is not configurable.
PUPPETEER_USER_DATA_DIR=./.chrome-profile
# Optional: path to a local Chrome/Chromium binary (otherwise puppeteer downloads its own)
# PUPPETEER_EXECUTABLE_PATH=

# --- Debug ---
# 'true' to dump full-page screenshots + HTML snapshots into ./debug-screenshots/
# during the auth flow. Off by default.
DEBUG_SCREENSHOTS=false
